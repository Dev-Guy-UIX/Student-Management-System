#include <stdio.h>
#include <string.h>

#define MAX 100

typedef struct
{
    char nom[50];
    int matricule;
} étudiant ;

étudiant liste[MAX];
int n = 0;

int main()
{
    int choix, pos, mat, i;

    do
    {
        printf("\n1-Ajouter\n2-Supprimer\n3-Inserer\n4-Afficher\n0-Quitter\n");
        printf("Choix : ");
        scanf("%d", &choix);

        switch (choix)
        {
            case 1: // Ajouter
                printf("Nom : ");
                scanf("%s", liste[n].nom);

                printf("Matricule : ");
                scanf("%d", &liste[n].matricule);

                n++;
                break;

            case 2: // Supprimer
                printf("Matricule a supprimer : ");
                scanf("%d", &mat);

                for (i = 0; i < n; i++)
                {
                    if (liste[i].matricule == mat)
                    {
                        for (int j = i; j < n - 1; j++)
                        {
                            liste[j] = liste[j + 1];
                        }

                        n--;
                    }
                }
                break;

            case 3: // Inserer
                printf("Position : ");
                scanf("%d", &pos);

                for (i = n; i >= pos; i--)
                {
                    liste[i] = liste[i - 1];
                }

                printf("Nom : ");
                scanf("%s", liste[pos - 1].nom);

                printf("Matricule : ");
                scanf("%d", &liste[pos - 1].matricule);

                n++;
                break;

            case 4: // Afficher
                for (i = 0; i < n; i++)
                {
                    printf("%s - %d\n",
                           liste[i].nom,
                           liste[i].matricule);
                }
                break;
        }

    } while (choix != 0);

    return 0;
}