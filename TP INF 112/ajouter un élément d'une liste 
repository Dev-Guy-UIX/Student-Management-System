void supprimer()
{
    int matricule;
    int i, trouve = 0;

    if (taille == 0)
    {
        printf("La liste est vide.\n");
        return;
    }

    printf("Entrer le matricule a supprimer : ");
    scanf("%d", &matricule);

    for (i = 0; i < taille; i++)
    {
        if (liste[i].matricule == matricule)
        {
            trouve = 1;

            for (int j = i; j < taille - 1; j++)
            {
                liste[j] = liste[j + 1];
            }

            taille--;

            printf("Personne supprimee.\n");
            break;
        }
    }

    if (!trouve)
    {
        printf("Matricule introuvable.\n");
    }
}


void inserer()
{
    int position;
    int i;

    if (taille >= MAX)
    {
        printf("La liste est pleine.\n");
        return;
    }

    printf("Entrer la position d'insertion : ");
    scanf("%d", &position);

    if (position < 1 || position > taille + 1)
    {
        printf("Position invalide.\n");
        return;
    }

    // Décalage vers la droite
    for (i = taille; i >= position; i--)
    {
        liste[i] = liste[i - 1];
    }

    printf("Entrer le nom : ");
    scanf("%s", liste[position - 1].nom);

    printf("Entrer le matricule : ");
    scanf("%d", &liste[position - 1].matricule);

    taille++;

    printf("Insertion reussie.\n");
}


